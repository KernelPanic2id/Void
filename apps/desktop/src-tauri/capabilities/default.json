{
  "$schema": "../gen/schemas/desktop-capability.json",
  "identifier": "main-capability",
  "description": "Permissions pour le signaling et les websockets",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:default",
    "core:window:allow-minimize",
    "core:window:allow-toggle-maximize",
    "core:window:allow-close",
    "core:window:allow-start-dragging",
    "opener:default",
    "updater:default",
    "websocket:default",
    "log:default",
    {
      "identifier": "websocket:allow-connect",
      "allow": [
        {
          "url": "wss://*"
        }
      ]
    }
  ]
}